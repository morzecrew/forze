{
    "editor.codeLens": true,
    "files.associations": {
        "*.env*": "env",
        ".coveragerc": "ini",
        "uv.lock": "toml",
        "*.conf.tpl": "toml",
        "*.json.tpl": "jsonc",
        "*.conf": "toml",
        "*.tftpl": "plaintext"
    },
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.import_linter_cache": true,
        "**/.mypy_cache": true,
        "**/__marimo__": true,
        "**/.coverage": true,
        "dist/": true,
        "**/.devcontainer/": true,
        "**/.venv/": true,
        ".agent": true,
        ".claude": true,
        ".benchmarks": true,
        ".markdownlint.yaml": true,
        "CLAUDE.md": true,
        "CODE_OF_CONDUCT.md": true,
        "CODEOWNERS": true,
        "LICENSE": true,
        "uv.lock": true,
        "skills-lock.json": true,
        "SECURITY.md": true,
    },
    "cursorpyright.analysis.diagnosticMode": "workspace",
    "cursorpyright.analysis.typeCheckingMode": "strict",
    "python.analysis.typeCheckingMode": "strict",
    "python.analysis.diagnosticMode": "workspace",
    "cursorpyright.analysis.inlayHints.functionReturnTypes": true,
    "cursorpyright.analysis.inlayHints.variableTypes": true,
    "ty.diagnosticMode": "workspace",
    "cursorpyright.analysis.extraPaths": [
        "src"
    ],
    "cursorpyright.analysis.ignore": [
        "tests/**"
    ],
    "[json]": {
        "editor.tabSize": 2,
    },
    "[jsonc]": {
        "editor.tabSize": 2,
    },
    "[toml]": {
        "editor.tabSize": 4,
    },
    "[yaml]": {
        "editor.tabSize": 2,
    },
    "[github-actions-workflow]": {
        "editor.tabSize": 2,
    },
    "[markdown]": {
        "editor.tabSize": 4,
    },
    "emeraldwalk.runonsave": {
        "shell": "zsh",
        "commands": [
            {
                "match": "\\.d2$",
                "cmd": "just pages diagrams"
            }
        ]
    },
    "[d2]": {
        "editor.tabSize": 2,
    },
}
