style: {
    fill: transparent
}

vars: {
    d2-config: {
        pad: 50
    }
}

direction: right

Before: {
    shape: rectangle
    label: before steps
}

Wrap: {
    shape: rectangle
    label: wrap / tx scope
}

Handler: {
    shape: circle
    label: Handler
}

OnSuccess: {
    shape: rectangle
    label: on_success steps
}

AfterCommit: {
    shape: rectangle
    label: After-commit hooks
}

Before -> Wrap -> Handler -> OnSuccess
Handler -> AfterCommit: transactional flow
