style: {
    fill: transparent
}

vars: {
    d2-config: {
        pad: 40
    }
}

direction: right

Tenant: {
    shape: rectangle
    style: {
        stroke: "#4a90d9"
        stroke-width: 2
    }
    label: |md
        ### Tenant identity
        bound per request
    |
}

shared: {
    label: "Shared instance"
    style: {
        stroke-dash: 4
        font-size: 18
    }

    tagged: {
        shape: rectangle
        label: |md
            ### tagged
            tenant marker, filtered
            `tenant_aware`
        |
    }

    namespace: {
        shape: rectangle
        label: |md
            ### namespace
            per-tenant schema / bucket / dataset
            named or relation resolver
        |
    }
}

dedicated: {
    shape: rectangle
    style: {
        stroke: "#4a90d9"
    }
    label: |md
        ### dedicated
        per-tenant instance & credentials
        routed client
    |
}

Tenant -> shared.tagged: weakest
Tenant -> shared.namespace
Tenant -> dedicated: strongest
