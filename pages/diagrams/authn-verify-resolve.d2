style: {
    fill: transparent
}

vars: {
    d2-config: {
        pad: 40
    }
}

direction: right

Verify: {
    shape: rectangle
    label: |md
        ### Verify
        credential → proof
    |
}

Assertion: {
    shape: rectangle
    style: {
        stroke: "#4a90d9"
        stroke-width: 2
    }
    label: |md
        ### VerifiedAssertion
        _the seam_
    |
}

Resolve: {
    shape: rectangle
    style.stroke: "#2e7d32"
    label: |md
        ### Resolve
        → AuthnIdentity
    |
}

Verify -> Assertion
Assertion -> Resolve
