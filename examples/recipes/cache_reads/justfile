set shell := ["bash", "-cu"]

# Run the recipe against ephemeral Postgres + Redis, then tear it down.
run:
    docker compose up -d --wait
    uv run --directory ../../.. python -m examples.recipes.cache_reads.app
    docker compose down

# Start the infra only (leave it up for iterating).
up:
    docker compose up -d --wait

# Stop and remove the infra.
down:
    docker compose down
