{
  "folders": [
    {
      "name": "Core",
      "path": "src/forze",
    },
    {
      "name": "FastAPI",
      "path": "src/forze_fastapi",
    },
    {
      "name": "MongoDB",
      "path": "src/forze_mongo",
    },
    {
      "name": "PostgreSQL",
      "path": "src/forze_postgres",
    },
    {
      "name": "Redis",
      "path": "src/forze_redis",
    },
    {
      "name": "S3",
      "path": "src/forze_s3",
    },
    {
      "name": "Socket.IO",
      "path": "src/forze_socketio",
    },
    {
      "name": "Temporal",
      "path": "src/forze_temporal",
    },
    {
      "name": "SQS",
      "path": "src/forze_sqs",
    },
    {
      "name": "RabbitMQ",
      "path": "src/forze_rabbitmq",
    },
    {
      "name": "Mock",
      "path": "src/forze_mock",
    },
    {
      "name": "Tests",
      "path": "tests",
    },
    {
      "name": "Examples",
      "path": "examples",
    },
    {
      "name": "Documentation",
      "path": "pages",
    },
    {
      "name": "GitHub",
      "path": ".github",
    },
    {
      "name": "Agent Skills",
      "path": "skills",
    },
    {
      "name": "Root",
      "path": ".",
    }
  ],
  "settings": {
    "files.associations": {
      "*.env*": "env",
      ".coveragerc": "ini",
      "uv.lock": "toml",
      "*.conf.tpl": "toml",
      "*.json.tpl": "jsonc",
      "*.conf": "toml",
      "*.tftpl": "plaintext"
    },
    "files.exclude": {
      "**/__pycache__": true,
      "**/.pytest_cache": true,
      "**/.ruff_cache": true,
      "**/.import_linter_cache": true,
      "**/.mypy_cache": true,
      "**/__marimo__": true,
      "**/.coverage": true,
      "**/.cache": true,
      "dist/": true,
      "**/.devcontainer/": true,
      "**/.venv/": true,
      ".agent": true,
      ".claude": true,
      ".benchmarks": true,
      ".markdownlint.yaml": true,
      "CLAUDE.md": true,
      "CODE_OF_CONDUCT.md": true,
      "CODEOWNERS": true,
      "LICENSE": true,
      "uv.lock": true,
      "skills-lock.json": true,
      "SECURITY.md": true,
    },
    "cursorpyright.analysis.diagnosticMode": "workspace",
    "cursorpyright.analysis.typeCheckingMode": "strict",
    "python.analysis.typeCheckingMode": "strict",
    "python.analysis.diagnosticMode": "workspace",
    "cursorpyright.analysis.inlayHints.functionReturnTypes": true,
    "cursorpyright.analysis.inlayHints.variableTypes": true,
    "ty.diagnosticMode": "workspace",
    "python.defaultInterpreterPath": "${workspaceFolder:Root}/.venv/bin/python",
    "cursorpyright.analysis.extraPaths": [
      "${workspaceFolder:Root}/src"
    ],
    "cursorpyright.analysis.ignore": [
      "${workspaceFolder:Root}/tests/**"
    ],
    "[json]": {
      "editor.tabSize": 2,
    },
    "[jsonc]": {
      "editor.tabSize": 2,
    },
    "[toml]": {
      "editor.tabSize": 4,
    },
    "[yaml]": {
      "editor.tabSize": 2,
    },
    "[github-actions-workflow]": {
      "editor.tabSize": 2,
    },
    "[markdown]": {
      "editor.tabSize": 4,
    },
    "[d2]": {
      "editor.tabSize": 2,
    },
    "emeraldwalk.runonsave": {
      "shell": "zsh",
      "commands": [
        {
          "match": "\\.d2$",
          "cmd": "just -f ${workspaceFolder:Root}/justfile pages diagrams"
        }
      ]
    },
  },
  "extensions": {
    "recommendations": [
      "emeraldwalk.runonsave",
      "nefrob.vscode-just-syntax"
    ]
  }
}
